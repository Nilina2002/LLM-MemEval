# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Application
APP_NAME=LLM-MemEval
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite for development — change URL for PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./memeval.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/memeval

# LLM Provider API Keys (set only the ones you'll use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# Output
RESULTS_DIR=results
EXPERIMENTS_DIR=experiments

# CORS (frontend origin)
ALLOWED_ORIGINS=["http://localhost:3000"]
